{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability for FBI desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "notification:allow-show",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission"
  ]
}
